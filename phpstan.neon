includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    paths:
        - src
        - config
        - database
    #        - routes

    configDirectories:
        - config

    # 8/9 -> libraries
    level: 8

    tmpDir: /tmp/phpstan
    inferPrivatePropertyTypeFromConstructor: true
    databaseMigrationsPath:
        - database/migrations
