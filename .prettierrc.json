{
    "$schema": "https://json.schemastore.org/prettierrc",
    "semi": true,
    "singleQuote": true,
    "singleAttributePerLine": false,
    "htmlWhitespaceSensitivity": "css",
    "tabWidth": 4,
    "printWidth": 150,
    "trailingComma": "none",
    "plugins": [
        "prettier-plugin-blade",
        "prettier-plugin-tailwindcss"
    ],
    "tailwindFunctions": [
        "clsx",
        "cn"
    ],
    "tailwindStylesheet": "./resources/css/glimpse.css",
    "overrides": [
        {
            "files": "**/*.blade.php",
            "options": {
                "parser": "blade",
                "singleQuote": true
            }
        },
        {
            "files": "**/*.yml",
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
